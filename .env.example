# AI Gateway Configuration (required)
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1

# Model (optional, defaults to @makers/deepseek-v3)
# AI_GATEWAY_MODEL=@makers/deepseek-v3

# ─── Business API Integration (optional) ────────────────────────────────────
# Provide your REST API base URL so the AI can query your backend in real time.
# Also place an api-schema.json in the project root to describe your endpoints.
# DATA_API_BASE_URL=https://api.example.com
# DATA_API_KEY=your-api-key
